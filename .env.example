# BrandArmor v4 - Environment Variables
# The app runs with local JSON-file persistence by default.

# Data directory for local JSON-file store (default: .brandarmor-data/).
# Keep this unset on Vercel/Lambda; serverless runtime uses the platform temp dir
# automatically (/tmp on Vercel).
# BRANDARMOR_DATA_DIR=.brandarmor-data/

# Required for the main v4 OCR demo path. Do not commit real keys.
# MISTRAL_API_KEY=...

# Optional: Perplexity Search/Sonar key for candidate discovery.
# PERPLEXITY_API_KEY=pplx-...

# Optional: Anthropic key for Claude evidence judge.
# ANTHROPIC_API_KEY=...

# Model routing. OCR is extraction; the judge only analyzes cited evidence.
BRANDARMOR_OCR_PROVIDER=mistral
BRANDARMOR_OCR_MODEL=mistral-ocr-latest
BRANDARMOR_LLM_JUDGE_PROVIDER=anthropic
BRANDARMOR_LLM_JUDGE_MODEL=claude-sonnet-4-5
BRANDARMOR_LLM_JUDGE_FALLBACK_PROVIDER=mistral
BRANDARMOR_LLM_JUDGE_FALLBACK_MODEL=mistral-large-latest

# Optional: Hugging Face API token for future image similarity / OCR benchmarks.
# HF_API_TOKEN=hf_...

# Optional: Browser-Use endpoint for user-guided evidence capture.
# BROWSER_USE_ENDPOINT=http://localhost:8000
