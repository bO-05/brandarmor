{
    "name": "brandarmor-v4",
    "version": "0.4.2",
    "private": true,
    "scripts": {
        "predev": "node scripts/patch-next-trace.cjs",
        "dev": "next dev -p 3015",
        "predev:3000": "node scripts/patch-next-trace.cjs",
        "dev:3000": "next dev -p 3000",
        "build": "next build",
        "start": "next start",
        "typecheck": "tsc --noEmit",
        "test": "vitest run",
        "test:watch": "vitest",
        "verify:env": "node scripts/verify-environment.cjs",
        "verify:core": "node --experimental-strip-types --loader ./tests/loader.js tests/core-workflow-direct-verify.mjs"
    },
    "dependencies": {
        "@vercel/speed-insights": "^2.0.0",
        "lucide-react": "^0.460.0",
        "next": "^15.5.7",
        "react": "^19.1.0",
        "react-dom": "^19.1.0",
        "sonner": "^1.7.0",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.0.0",
        "@types/node": "^22.0.0",
        "@types/react": "^19.1.0",
        "@types/react-dom": "^19.1.0",
        "postcss": "^8.5.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.7.0",
        "vitest": "^3.1.0"
    },
    "type": "module",
    "engines": {
        "node": ">=20.19.0"
    },
    "overrides": {
        "postcss": "$postcss"
    },
    "imports": {
        "@/*": "./src/*"
    }
}
